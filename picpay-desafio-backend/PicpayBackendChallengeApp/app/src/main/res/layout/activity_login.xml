<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:layout_height="match_parent"
    android:paddingVertical="10dp"
    tools:context=".ui.login.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/container_email_input"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/login_bg_img"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="25sp"
            android:textColor="#413f58"
            android:textStyle="bold"
            android:fontFamily="@font/roboto"
            android:text="Welcome back!" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_email_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/container_password_input">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="7dp"
            android:text="E-mail adress" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/email_textfield"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:endIconDrawable="@drawable/mail_24px"
            app:endIconMode="custom"
            app:hintEnabled="false"
            app:endIconCheckable="true">

            <com.google.android.material.textfield.TextInputEditText
                android:hint="Enter your e-mail"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_password_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/view_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:layout_marginBottom="7dp"
                android:text="Password" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"

                android:selectAllOnFocus="false"
                android:linksClickable="false"
                android:autoLink="all"

                android:layout_marginBottom="7dp"
                android:text="Forgot password?" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/password_textfield"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:endIconDrawable="@drawable/visibility_24px"
            app:endIconMode="custom"
            app:hintEnabled="false"
            app:endIconCheckable="true">

            <com.google.android.material.textfield.TextInputEditText
                android:hint="Enter your password"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>


    <LinearLayout
        android:id="@+id/view_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@+id/container_login_btns"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.divider.MaterialDivider
            app:dividerColor="#ececf3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:dividerThickness="2dp"
            android:layout_weight="1"
            app:dividerInsetEnd="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:textColor="#ececf3"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="or" />

        <com.google.android.material.divider.MaterialDivider
            app:dividerColor="#ececf3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:dividerThickness="2dp"
            android:layout_weight="1"
            app:dividerInsetStart="20dp" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/container_login_btns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:layout_constraintBottom_toTopOf="@+id/btn_login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:paddingHorizontal="40dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal">


        <ImageButton
            android:id="@+id/btn_login_google"
            android:src="@drawable/google_icon"
            android:scaleType="centerCrop"
            android:background="@drawable/button_other_login_bg"

            android:layout_width="55dp"
            android:layout_height="55dp"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/btn_login"

            />

        <Space
            android:layout_width="30dp"
            android:layout_height="1dp" >
        </Space>

        <ImageButton
            android:id="@+id/btn_login_facebook"
            android:src="@drawable/facebook_icon"
            android:scaleType="centerCrop"
            android:background="@drawable/button_other_login_bg"

            android:layout_width="55dp"
            android:layout_height="55dp"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/btn_login"

            />

        <Space
            android:layout_width="30dp"
            android:layout_height="1dp" >
        </Space>

        <ImageButton
            android:id="@+id/btn_login_apple"
            android:src="@drawable/apple_logo"
            android:scaleType="fitCenter"
            android:background="@drawable/button_other_login_bg"

            android:layout_width="55dp"
            android:layout_height="55dp"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/btn_login"
            />

    </LinearLayout>


    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/view_create_account"
        android:layout_marginBottom="10dp"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/button_login_bg"
        app:backgroundTint="#1e1d2e"
        android:textColor="@color/white"
        android:fontFamily="@font/roboto"
        android:textStyle="bold"
        android:textSize="16sp"
        android:text="Log in ->" />

    <LinearLayout
        android:id="@+id/view_create_account"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto"
            android:textSize="15sp"
            android:text="Don't have an account? " />

        <TextView
            android:id="@+id/txt_link_create_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto"
            android:textSize="15sp"
            android:text="Sign up now"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>